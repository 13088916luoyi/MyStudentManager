         <property name="styleSheet">
          <string notr="true">/* 表格整体：设置网格线颜色，让表格更清晰 */
QTableView {
    gridline-color: #E5E5E5;
    outline: none; /* 去掉点击时的虚线框 */
}

/* 表头：设置背景色和文字色，更美观 */
QHeaderView::section {
    background-color: #F5F5F5;
    color: #333333;
    padding: 6px;
    border: 1px solid #E0E0E0;
    font-weight: bold;
}

/* 【核心】选中行：设置背景色和文字色，整行高亮 */
QTableView::item:selected {
    background-color: #0078D4; /* 亮蓝色背景，你可以改成 #2196F3 或 #107C10 */
    color: #FFFFFF;             /* 白色文字，和背景形成强烈对比 */
}

/* 【补充】即使窗口失去焦点，选中行也保持高亮，不会变灰 */
QTableView::item:selected:!active {
    background-color: #0078D4;
    color: #FFFFFF;
}</string>
